{
	"name": "hastypes",
	"version": "4.0.4",
	"description": "Does the given package have TypeScript types?",
	"bin": "./bin.mjs",
	"main": "./index.mjs",
	"exports": {
		".": "./index.mjs",
		"./package.json": "./package.json"
	},
	"sideEffects": false,
	"scripts": {
		"prepack": "npmignore --auto --commentLines=autogenerated",
		"version": "auto-changelog && git add CHANGELOG.md",
		"postversion": "auto-changelog && git add CHANGELOG.md && git commit --no-edit --amend && git tag -f \"v$(node -e \"console.log(require('./package.json').version)\")\"",
		"prepublishOnly": "safe-publish-latest",
		"prepublish": "not-in-publish || npm run prepublishOnly",
		"lint": "eslint .",
		"postlint": "tsc -p . && attw -P",
		"pretest": "npm run lint",
		"tests-only": "tape test/*.*js",
		"test": "npm run tests-only",
		"posttest": "npx npm@'>=10.2' audit --production"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/inspect-js/has-types.git"
	},
	"keywords": [
		"npm",
		"package",
		"typescript",
		"ts",
		"types",
		"typings",
		"definitelytyped",
		"dt"
	],
	"author": "Elliot Blackburn <elliot@lybrary.io>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/inspect-js/has-types/issues"
	},
	"homepage": "https://github.com/inspect-js/has-types#readme",
	"dependencies": {
		"dts-gen": "^0.10.9",
		"es-errors": "^1.3.0",
		"get-dep-tree": "^3.0.0",
		"mock-property": "^1.1.2",
		"npm-package-arg": "^14.0.0",
		"pacote": "^22.0.0",
		"pargs": "^1.4.2",
		"safe-regex-test": "^1.1.0",
		"semver": "^7.8.5",
		"tmp": "^0.2.7"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@ljharb/eslint-config": "^22.2.3",
		"@ljharb/tsconfig": "^0.3.2",
		"@types/node": "^24.13.2",
		"@types/npm-package-arg": "^6.1.4",
		"@types/semver": "^7.7.1",
		"@types/tmp": "^0.2.6",
		"auto-changelog": "^2.6.0",
		"eslint": "^10.5.0",
		"in-publish": "^2.0.1",
		"jiti": "^0.0.0",
		"npmignore": "^0.3.5",
		"safe-publish-latest": "^2.0.0",
		"tape": "^5.10.2",
		"typescript": "next"
	},
	"auto-changelog": {
		"output": "CHANGELOG.md",
		"template": "keepachangelog",
		"unreleased": false,
		"commitLimit": false,
		"backfillLimit": false,
		"hideCredit": true
	},
	"publishConfig": {
		"ignore": [
			".github/workflows"
		]
	},
	"engines": {
		"node": "^24.16 || >= 26.3"
	}
}
